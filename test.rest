### Variables
@baseUrl = http://localhost:3000
@contentType = application/json

### Test root endpoint
GET {{baseUrl}}/

### Get all contacts
GET {{baseUrl}}/contacts

### Get contact by ID
GET {{baseUrl}}/contacts/69ab459daf86ae5c10e5cb8c

### Create a new contact
POST {{baseUrl}}/contacts
Content-Type: {{contentType}}

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john.doe@example.com",
  "favoriteColor": "Orange",
  "birthday": "08/15/1990"
}

### Update a contact
PUT {{baseUrl}}/contacts/69ab459daf86ae5c10e5cb8c
Content-Type: {{contentType}}

{
  "firstName": "Jane",
  "lastName": "Smith",
  "email": "jane.smith@example.com",
  "favoriteColor": "Blue",
  "birthday": "09/20/1992"
}

### Delete a contact
DELETE {{baseUrl}}/contacts/69ab451baf86ae5c10e5cb8b
